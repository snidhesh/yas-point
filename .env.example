# ─── SERVER-SIDE (Vercel serverless function api/lead.js) ───
#
# CRM bearer token — used by api/lead.js to authenticate with the BlackOak RE
# CRM intake endpoint (https://studio.blackoak-re.com/api/v1/public/intake/leads).
#
# Set this in the Vercel dashboard for production. For local development with
# `vercel dev`, put it in a local .env file (which is gitignored).
#
# WITHOUT this var, api/lead.js returns 500 "Server misconfigured".
CRM_TOKEN=
