# ─── SERVER-SIDE (Vercel serverless function api/lead.js) ───
#
# Set these in the Vercel dashboard for production:
#   Settings → Environment Variables → add for Production + Preview + Development
#
# For local dev with `vercel dev`, put them in a local .env file (gitignored).

# CRM_TOKEN — REQUIRED
# Bearer token for the CRM intake API. Same value as bashayer uses.
# WITHOUT this, api/lead.js returns 500 "Server misconfigured".
CRM_TOKEN=

# CRM_URL — OPTIONAL
# Full URL of the CRM intake endpoint. Override this to point at a staging
# CRM, a self-hosted instance, or a different provider entirely.
# Default: https://studio.blackoak-re.com/api/v1/public/intake/leads
CRM_URL=

# CRM_SOURCE — OPTIONAL
# Written into the lead's "source" field so the CRM can segment leads by
# landing page (e.g. filter yaspoint leads separately from bashayer).
# Default: yaspoint-landing
CRM_SOURCE=
