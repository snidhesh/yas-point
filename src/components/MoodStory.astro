---
import MoodPoster from './MoodPoster.astro';

interface Props {
  eyebrow: string;
  posterKicker: string;
  posterHeadline: string;
  posterBody?: string;
  posterSrc: string;
  posterAlt: string;
  title: string;
  titleAccent?: string;
  body: string;
  meta?: { label: string; value: string }[];
  reverse?: boolean;
  tone?: 'light' | 'dark' | 'sand' | 'linen';
  eager?: boolean;
  chapter?: string;
  chapterLabel?: string;
}

const {
  eyebrow,
  posterKicker,
  posterHeadline,
  posterBody,
  posterSrc,
  posterAlt,
  title,
  titleAccent,
  body,
  meta = [],
  reverse = false,
  tone = 'light',
  eager = false,
  chapter,
  chapterLabel,
} = Astro.props;

const toneClass = {
  light: 'bg-paper text-ink',
  dark: 'bg-midnight text-paper grain-overlay',
  sand: 'bg-sand text-ink',
  linen: 'bg-linen text-ink',
}[tone];

const eyebrowClass = tone === 'dark' ? 'text-gold' : '';
const titleAccentClass = tone === 'dark' ? 'text-paper/45 italic' : 'text-ink/45 italic';
const bodyClass = tone === 'dark' ? 'text-paper/80' : 'text-ink/75';
const metaLabelClass = tone === 'dark' ? 'text-paper/50' : 'text-ink/50';
const metaValueClass = tone === 'dark' ? 'text-paper' : 'text-midnight';
const metaBorderClass = tone === 'dark' ? 'border-paper/15' : 'border-midnight/10';
---
<section
  id={chapter ? `chapter-${chapter}` : undefined}
  class={`${toneClass} py-6 xs:py-8 sm:py-12 md:py-14 lg:py-16 overflow-hidden`}
  data-chapter={chapter}
  data-chapter-label={chapterLabel}
  style="scroll-margin-top: 0;"
>
  <div class={`mx-auto max-w-6xl px-5 sm:px-6 md:px-10 grid md:grid-cols-2 gap-5 xs:gap-6 sm:gap-10 md:gap-14 lg:gap-16 items-center ${reverse ? 'md:[direction:rtl]' : ''}`}>
    <div class={`${reverse ? 'md:[direction:ltr]' : ''} reveal`}>
      <MoodPoster
        src={posterSrc}
        alt={posterAlt}
        kicker={posterKicker}
        headline={posterHeadline}
        body={posterBody}
        eager={eager}
      />
    </div>

    <div class={`${reverse ? 'md:[direction:ltr]' : ''} reveal`}>
      <p class:list={['eyebrow', eyebrowClass]}>{eyebrow}</p>
      <h2 class="display text-2xl xs:text-fluid-h2 md:text-fluid-h1 mt-3 xs:mt-4 sm:mt-6">
        {title}
        {titleAccent && (<><br/><span class={titleAccentClass}>{titleAccent}</span></>)}
      </h2>
      <p class:list={['mt-3 xs:mt-4 sm:mt-8 text-sm xs:text-fluid-body sm:text-fluid-lead leading-snug xs:leading-relaxed font-light max-w-prose', bodyClass]}>
        {body}
      </p>

      {meta.length > 0 && (
        <dl class={`mt-4 xs:mt-6 sm:mt-10 grid grid-cols-2 gap-x-4 sm:gap-x-8 gap-y-3 xs:gap-y-4 sm:gap-y-6 pt-3 xs:pt-4 sm:pt-8 border-t ${metaBorderClass}`}>
          {meta.map((m) => (
            <div>
              <dt class:list={['text-[9px] xs:text-[10px] sm:text-[11px] uppercase tracking-eyebrow2 leading-tight', metaLabelClass]}>{m.label}</dt>
              <dd class:list={['font-display text-base xs:text-lg sm:text-2xl md:text-3xl mt-1 sm:mt-2 leading-tight tnum', metaValueClass]}>{m.value}</dd>
            </div>
          ))}
        </dl>
      )}
    </div>
  </div>
</section>
