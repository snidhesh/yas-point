---
import BrandMark from './BrandMark.astro';
---
<section class="relative min-h-[100svh] w-full flex flex-col bg-deep text-paper overflow-hidden grain-overlay">

  <!-- Atmospheric SVG backdrop -->
  <div class="absolute inset-0 z-0" aria-hidden="true">
    <svg viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice" class="absolute inset-0 w-full h-full">
      <defs>
        <linearGradient id="hero-sky" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0"     stop-color="#050A12"/>
          <stop offset="55%"   stop-color="#0F1F2E"/>
          <stop offset="100%"  stop-color="#0F2540"/>
        </linearGradient>
        <radialGradient id="hero-glow" cx="80%" cy="24%" r="55%">
          <stop offset="0"    stop-color="#93B4CE" stop-opacity="0.35"/>
          <stop offset="35%"  stop-color="#93B4CE" stop-opacity="0.08"/>
          <stop offset="100%" stop-color="#93B4CE" stop-opacity="0"/>
        </radialGradient>
        <linearGradient id="hero-horizon" x1="0" y1="0" x2="1" y2="0">
          <stop offset="0"    stop-color="#93B4CE" stop-opacity="0"/>
          <stop offset="50%"  stop-color="#93B4CE" stop-opacity="0.28"/>
          <stop offset="100%" stop-color="#93B4CE" stop-opacity="0"/>
        </linearGradient>
        <linearGradient id="hero-water" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0"    stop-color="#0F2540" stop-opacity="0.5"/>
          <stop offset="100%" stop-color="#050A12" stop-opacity="1"/>
        </linearGradient>
        <linearGradient id="hero-vignette" x1="0" y1="1" x2="0" y2="0">
          <stop offset="0"    stop-color="#050A12" stop-opacity="0.85"/>
          <stop offset="45%"  stop-color="#050A12" stop-opacity="0.3"/>
          <stop offset="100%" stop-color="#050A12" stop-opacity="0"/>
        </linearGradient>
      </defs>
      <rect width="1440" height="900" fill="url(#hero-sky)"/>
      <rect width="1440" height="900" fill="url(#hero-glow)"/>
      <g fill="#F5F8FB">
        <circle cx="80"   cy="90"  r="0.9" opacity="0.6"/>
        <circle cx="180"  cy="140" r="0.6" opacity="0.4"/>
        <circle cx="290"  cy="70"  r="0.8" opacity="0.55"/>
        <circle cx="410"  cy="180" r="0.5" opacity="0.35"/>
        <circle cx="520"  cy="110" r="0.7" opacity="0.5"/>
        <circle cx="640"  cy="60"  r="0.9" opacity="0.65"/>
        <circle cx="750"  cy="150" r="0.5" opacity="0.4"/>
        <circle cx="1050" cy="130" r="0.5" opacity="0.3"/>
        <circle cx="1340" cy="100" r="0.7" opacity="0.45"/>
      </g>
      <rect x="0" y="576" width="1440" height="14" fill="url(#hero-horizon)"/>
      <line x1="0" y1="582" x2="1440" y2="582" stroke="#F5F8FB" stroke-opacity="0.12"/>
      <rect x="0" y="590" width="1440" height="310" fill="url(#hero-water)"/>
      <g fill="#93B4CE">
        <circle cx="60"   cy="583" r="1.3" opacity="0.7"/>
        <circle cx="185"  cy="583" r="1.5" opacity="0.75"/>
        <circle cx="320"  cy="583" r="1.2" opacity="0.65"/>
        <circle cx="410"  cy="583" r="1.5" opacity="0.8"/>
        <circle cx="560"  cy="583" r="1.3" opacity="0.7"/>
        <circle cx="740"  cy="583" r="1.5" opacity="0.75"/>
        <circle cx="900"  cy="583" r="1.3" opacity="0.7"/>
        <circle cx="1050" cy="582" r="1.2" opacity="0.6"/>
      </g>
      <g stroke="#F5F8FB" fill="none">
        <path d="M0 700 Q 360 685 720 700 T 1440 700" stroke-opacity="0.08"/>
        <path d="M0 750 Q 360 735 720 750 T 1440 750" stroke-opacity="0.06"/>
      </g>
      <rect x="0" y="500" width="1440" height="400" fill="url(#hero-vignette)"/>
    </svg>
  </div>

  <!-- Top nav -->
  <div class="relative z-20 w-full">
    <div class="mx-auto max-w-7xl px-5 sm:px-6 md:px-10 pt-[calc(env(safe-area-inset-top)+1.25rem)] pb-4 flex items-center justify-between gap-4">
      <BrandMark tone="light" />
      <div class="hidden sm:flex items-center gap-6 lg:gap-8">
        <span class="inline-flex items-center gap-3 text-[10px] uppercase tracking-eyebrow2 text-paper/55">
          <span class="inline-block w-6 h-px bg-paper/25"></span>
          <span class="text-gold font-medium">Chapter I</span>
          <span class="text-paper/25">·</span>
          <span>The Groves</span>
        </span>
        <a href="#register" class="btn-ghost text-paper/80 hover:text-paper">
          Register
        </a>
      </div>
    </div>
  </div>

  <!-- Hero content: two-column at md+, stacked below -->
  <div class="relative z-10 flex-1 w-full flex items-center py-8 md:py-12">
    <div class="mx-auto w-full max-w-7xl px-5 sm:px-6 md:px-10">
      <div class="grid md:grid-cols-12 gap-10 md:gap-12 lg:gap-16 items-center">

        <!-- Text column -->
        <div class="md:col-span-7 lg:col-span-7 order-2 md:order-1">
          <p class="eyebrow-plain text-gold">A story beyond the horizon</p>

          <h1 class="display text-fluid-display mt-5 sm:mt-6">
            <span class="block">A coast</span>
            <span class="block italic text-gold font-light">still being written.</span>
          </h1>

          <div class="mt-6 sm:mt-8 md:mt-10 max-w-xl">
            <p class="text-fluid-lead text-paper/80 font-light">
              A new waterfront district is rising &mdash; next door to the world&rsquo;s
              most iconic playground, where the sea meets the horizon and the
              horizon meets the extraordinary.
            </p>
          </div>

          <div class="mt-8 sm:mt-10 flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-5">
            <a href="#register" class="btn-primary bg-gold text-midnight hover:bg-paper hover:text-midnight w-full sm:w-auto">
              Be the first to know
              <span class="arrow" aria-hidden="true">→</span>
            </a>
            <a href="#imagine" class="btn-ghost text-paper/70 hover:text-paper sm:pl-2 justify-center sm:justify-start">
              Step inside the vision
            </a>
          </div>
        </div>

        <!-- Image column — cinematic mood poster -->
        <div class="md:col-span-5 lg:col-span-5 order-1 md:order-2">
          <figure class="relative w-full aspect-[3/4] overflow-hidden rounded-2xl md:rounded-3xl shadow-2xl bg-midnight">
            <img
              src="/images/garden.jpeg"
              alt="A figure in a flowing dress moving through a glowing garden at dusk"
              fetchpriority="high"
              class="absolute inset-0 w-full h-full object-cover"
            />
            <div class="absolute inset-x-0 bottom-0 h-[30%] bg-gradient-to-t from-black/60 to-transparent" aria-hidden="true"></div>
            <figcaption class="absolute bottom-5 left-5 md:bottom-6 md:left-6 text-[10px] uppercase tracking-eyebrow2 text-paper/70">
              <span class="inline-block w-4 h-px bg-gold mr-2 align-middle"></span>
              Where the garden glows to life
            </figcaption>
          </figure>
        </div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-6 right-6 md:bottom-10 md:right-10 z-20 hidden md:flex flex-col items-center gap-3 text-[10px] uppercase tracking-eyebrow2 text-paper/45">
    <span>Scroll</span>
    <span class="block h-16 w-px bg-gradient-to-b from-paper/40 to-transparent"></span>
  </div>
</section>
