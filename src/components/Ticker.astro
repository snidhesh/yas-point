---
const words = [
  'the canal',
  'the park',
  'the beach',
  'the marina',
  'the resort',
  'the magic',
  'the mornings',
  'the memories',
];
---
<section class="no-stack bg-deep text-paper py-5 sm:py-6 md:py-7 border-y border-paper/10 grain-overlay overflow-hidden">
  <div class="mx-auto max-w-6xl px-5 sm:px-6 md:px-10 flex flex-wrap items-center justify-center gap-x-3 sm:gap-x-4 md:gap-x-5 gap-y-2">
    {words.map((w, i) => (
      <>
        <span class="font-display italic text-xs sm:text-sm md:text-base text-paper/75 tracking-tight2">{w}</span>
        {i < words.length - 1 && (
          <span class="inline-block w-[3px] h-[3px] sm:w-1 sm:h-1 rounded-full bg-gold/70 shrink-0" aria-hidden="true"></span>
        )}
      </>
    ))}
  </div>
</section>
